PORT=3001
NODE_ENV=development
JWT_SECRET=your_super_safe_jwt_secret_here_make_it_long
MONERO_WALLET_PASSWORD=your_secure_wallet_password
MONERO_WALLET_ADDRESS=your_primary_address
MONERO_VIEW_KEY=your_private_view_key
MONERO_WALLET_RPC_URL=http://your-monero-node:18081
MONERO_NODE_URL=https://node.sethforprivacy.com:443
# extra monerod endpoints for failover, comma/space separated. the shared
# nodePool health-probes all of them and prefers the live, on-tip, lowest-latency one.
MONERO_NODE_FALLBACKS=https://xmr-node.cakewallet.com:18081
# nodes you know send CORS headers — seeded as browser-reachable so the
# client-side WASM scanner can use them before the first probe round (still verified).
MONERO_CORS_NODES=
# socks5 proxy for reaching .onion nodes, e.g. socks5h://127.0.0.1:9050 (optional)
MONERO_TOR_PROXY=
ALTCHA_HMAC_KEY=optional_manual_key_for_captcha
